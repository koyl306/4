<Page
    x:Class="pract10.AddExpPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:pract10"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>

        <RelativePanel>

            <StackPanel
                x:Name="Experiment"
                Margin="20">

                <TextBox
                    Text="{x:Bind ViewModel.NewTitle, Mode=TwoWay}"
                    Header="Назва експерименту"/>

                <TextBox
                    Text="{x:Bind ViewModel.NewEquipment, Mode=TwoWay}"
                    Header="Обладнання"
                    Margin="0,14,0,0"/>

                <TextBox
                    Text="{x:Bind ViewModel.NewResult, Mode=TwoWay}"
                    Header="Результат"
                    Margin="0,14,0,0"/>

            </StackPanel>

            <StackPanel
                Orientation="Horizontal"
                RelativePanel.Below="Experiment">

                <Button
                    Content="Зберегти"
                    Margin="14"
                    Click="Button_Click"/>

                <Button
                    Content="Очистити"
                    Margin="4"
                    Click="Button_Click_1"/>

            </StackPanel>

        </RelativePanel>

    </Grid>

</Page>