<Page
    x:Class="pract10.ExpPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:pract10"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>

        <ListView
            ItemsSource="{x:Bind ViewModel.Experiments, Mode=OneWay}">

            <ListView.HeaderTemplate>

                <DataTemplate>

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="ID"
                                   Width="50"/>

                        <TextBlock Text="Title"
                                   Width="150"/>

                        <TextBlock Text="Equipment"
                                   Width="150"/>

                        <TextBlock Text="Result"
                                   Width="150"/>

                    </StackPanel>

                </DataTemplate>

            </ListView.HeaderTemplate>

            <ListView.ItemTemplate>

                <DataTemplate x:DataType="local:Experiment">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="{x:Bind Id}"
                                   Width="50"/>

                        <TextBlock Text="{x:Bind Name}"
                                   Width="150"/>

                        <TextBlock Text="{x:Bind UsedMaterial}"
                                   Width="150"/>

                        <TextBlock Text="{x:Bind Result}"
                                   Width="150"/>

                    </StackPanel>

                </DataTemplate>

            </ListView.ItemTemplate>

        </ListView>

    </Grid>
</Page>