<Window
    x:Class="pract7.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Width="950" Height="500">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Spacing="10"
                    Margin="10">

            <TextBlock Text="Назва експерименту"/>

            <TextBox x:Name="TextBoxName"
                     PlaceholderText="Введіть назву"/>

            <TextBlock Text="Матеріали / обладнання"/>

            <TextBox x:Name="TextBoxMaterial"
                     PlaceholderText="Введіть матеріали"/>

            <TextBlock Text="Результат"/>

            <TextBox x:Name="TextBoxResult"
                     PlaceholderText="Введіть результат"/>

            <Button Content="Додати"
                    Click="ButtonAdd_Click"/>

            <Button Content="Редагувати"
                    Click="ButtonEdit_Click"/>

            <Button Content="Видалити"
                    Click="ButtonDelete_Click"/>

            <Button Content="Очистити"
                    Click="ButtonClear_Click"/>

            <Button Content="Діалог"
                    Click="ButtonDialog_Click"/>

        </StackPanel>

        <ListView x:Name="listView"
                  Grid.Column="1"
                  SelectionChanged="listView_SelectionChanged">

            <ListView.ItemTemplate>

                <DataTemplate>

                    <StackPanel Orientation="Horizontal"
                                Spacing="10">

                        <TextBlock Text="{Binding ID}"
                                   Width="40"/>

                        <TextBlock Text="{Binding Name}"
                                   Width="180"/>

                        <TextBlock Text="{Binding Date}"
                                   Width="120"/>

                        <TextBlock Text="{Binding UsedMaterial}"
                                   Width="250"/>

                        <TextBlock Text="{Binding Result}"
                                   Width="200"/>

                    </StackPanel>

                </DataTemplate>

            </ListView.ItemTemplate>

        </ListView>

    </Grid>
</Window>