<Window
    x:Class="pract8.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:local="using:pract8"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel Padding="20" Spacing="10">

            <TextBlock Text="Керування лабораторією"
                       FontSize="26"
                       FontWeight="Bold"/>

            <TextBox Header="Назва"
                     Text="{x:Bind ViewModel.Name, Mode=TwoWay}"/>

            <TextBox Header="Матеріали"
                     Text="{x:Bind ViewModel.UsedMaterial, Mode=TwoWay}"/>

            <TextBox Header="Результат"
                     Text="{x:Bind ViewModel.Result, Mode=TwoWay}"/>

            <StackPanel Orientation="Horizontal" Spacing="10">

                <Button Content="Додати" Click="Add_Click"/>
                <Button Content="Очистити" Click="Clear_Click"/>
                <Button Content="Сортувати" Click="Sort_Click"/>

            </StackPanel>

            <ListView ItemsSource="{x:Bind ViewModel.Experiments, Mode=OneWay}">

                <!-- Заголовок таблиці -->
                <ListView.Header>
                    <Grid Padding="5" Background="LightGray">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="ID" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="Назва" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="Дата" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="Матеріали" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="Результат" FontWeight="Bold"/>
                    </Grid>
                </ListView.Header>

                <!-- Рядки -->
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:Experiment">

                        <Grid Padding="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                           Text="{x:Bind Id}"/>

                            <TextBlock Grid.Column="1"
                           Text="{x:Bind Name}"/>

                            <TextBlock Grid.Column="2"
                           Text="{x:Bind Date}"/>

                            <TextBlock Grid.Column="3"
                           Text="{x:Bind UsedMaterial}"/>

                            <TextBlock Grid.Column="4"
                           Text="{x:Bind Result}"/>

                        </Grid>

                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

        </StackPanel>
    </Grid>
</Window>