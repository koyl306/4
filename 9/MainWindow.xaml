<Window
    x:Class="pract9.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:pract9">

    <Grid Padding="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <ListView Grid.Column="0"
                  ItemsSource="{x:Bind VM.Experiments, Mode=OneWay}">

            <ListView.HeaderTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ID" Width="40"/>
                        <TextBlock Text="Name" Width="120"/>
                        <TextBlock Text="Date" Width="110"/>
                        <TextBlock Text="Material" Width="140"/>
                        <TextBlock Text="Result" Width="120"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.HeaderTemplate>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:Experiment">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Bind Id}" Width="40"/>
                        <TextBlock Text="{x:Bind Name}" Width="120"/>
                        <TextBlock Text="{x:Bind Date}" Width="110"/>
                        <TextBlock Text="{x:Bind UsedMaterial}" Width="140"/>
                        <TextBlock Text="{x:Bind Result}" Width="120"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

        <StackPanel Grid.Column="1" Spacing="10">

            <TextBox Header="Name"
                     Text="{x:Bind VM.Name, Mode=TwoWay}"/>

            <TextBox Header="Used material"
                     Text="{x:Bind VM.UsedMaterial, Mode=TwoWay}"/>

            <TextBox Header="Result"
                     Text="{x:Bind VM.Result, Mode=TwoWay}"/>

            <Button Content="Add experiment"
                    Click="Add_Click"/>

        </StackPanel>

    </Grid>

</Window>